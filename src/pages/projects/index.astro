---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts'; 
import BaseHead from '../../components/BaseHead.astro';

const posts = (await getCollection('projects')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section>
				<ul class="list-none ml-0 flex flex-wrap gap-4">
					{
						posts.map((post) => { 
							const isFrosted = post.data.title.toLowerCase().includes('frosted');

							return (
							<li class="no-underline flex-1/5 shrink-0 mb-8 p-2 border-[12px] [border-style:ridge]">
								{isFrosted && <frosted-glass color-rgb="0, 187, 255" melted-color-rgb="120,215,215" class="absolute -inset-2 rounded pointer-events-none"></frosted-glass>}
								<a class="group text-text-on-white darkDISABLED:text-text-on-dark hover:text-primary!" href={`/projects/${post.id}/`}>
									{post.data.heroImage && (
										<Image width={720} height={360} src={post.data.heroImage} alt="" />
									)}
									<h4 class="m-0 text-base font-bold leading-none">{post.data.title}</h4>
									<p class="m-0 text-muted group-hover:text-inherit text-xs">
										<FormattedDate date={post.data.pubDate} />
									</p>
								</a>
							</li>
						)})
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>

<script>
	import '@mycolaos/frosted-glass';
</script>
