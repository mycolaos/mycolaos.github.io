---
import { Image } from 'astro:assets';
import avatarImage from "/src/assets/images/avatar.jpg"

import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';
// Fetch and sort blog posts
const allPosts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const latestPost = allPosts[0];
const recentPosts = allPosts.slice(1, 4);

// Use the description from the post's frontmatter
const excerpt = latestPost.data.excerpt || '';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<div class="flex flex-col lg:flex-row gap-8 max-w-6xl mx-auto px-4 py-8">
			<main class="flex-1 min-w-0">
				<h1 class="text-5xl font-black mb-0">
					<div class="inline-block relative mr-4 w-24 h-24">
						<div id="avatar" class="transition-transform duration-2000 ease-in-out w-full h-full relative">
							<Image class="inline-block w-24 h-24 rounded-full" alt="Mycolaos photoshot elaborated in Borderlands style" src={avatarImage} />
								{Array.from({ length: 16 }).map((_, i) => (
									<span
										class="avatar-segment absolute block bg-black transform-3d"
										style={{
											width: '21px', // 2πr/16 ≈ 18.85 for r=48px
											height: '3px',
											left: 'calc(50% - 10.5px)',
											top: 'calc(50% - 1.5px)',
											transform: `rotate(${i * 22.5}deg) translateY(-48px)`,
											borderRadius: '2px',
										}}
									></span>
								))}
						</div>
					</div>
					Hello, Netwanderer!
				</h1>
				<div class="ml-28">
					<p>💡 Click a button</p>
					<div class="w-80 grid grid-cols-3 [grid-template-areas:'a_b_c'] gap-1 text-[saddlebrown] text-sm text-center font-bold select-none">
						<span tabindex="0" id="target-a" aria-role="fake-button" class="col-span-1 [grid-area:a] rounded-lg border-2 border-[saddlebrown] px-2 py-1 cursor-pointer">Target A</span>
						<span tabindex="0" id="target-b" aria-role="fake-button" class="col-span-1 [grid-area:b] rounded-lg border-2 border-[saddlebrown] px-2 py-1 cursor-pointer">Target B</span>
						<span explanation-for-devs="It holds area class name so Tailwind can generate it." class="[grid-area:c] -z-10"></span>
					</div>
				</div>
			</main>
			
			<aside class="lg:w-80 pt-16 flex-shrink-0">
				<div class="sticky top-8">
					<!-- Latest Post -->
					<div class="mb-6 px-3 py-6 border border-stone-300 rounded-lg bg-white/50 backdrop-blur-lg">
						<a href={`/blog/${latestPost.id}/`} class="group block">
							<h4 class="mt-0 mb-1 text-sm font-bold leading-tightgroup-hover:text-primary-dark">{latestPost.data.title}</h4>
							<p class="m-0 text-xs text-muted-dark leading-relaxed italic font-serif">{excerpt}</p>
						</a>
					</div>

					<!-- Explore -->
					<div>
						<h3 class="text-sm m-0 font-bold">Explore</h3>
						<ul class="space-y-0 list-none m-0">
							{recentPosts.map((post) => (
								<li>
									<a href={`/blog/${post.id}/`}>
										<h4 class="mt-1 mb-2 text-xs leading-tight hover:text-primary-dark">{post.data.title}</h4>
									</a>
								</li>
							))}
						</ul>
						<a href="/blog/" class="inline-block text-xs font-bold hover:text-primary-dark border-b-2 border-primary hover:border-primary-dark">
							More posts →
						</a>
					</div>
				</div>
			</aside>
		</div>
		
		<Footer />
	</body>
</html>
<style>

#avatar {
	perspective: 600px;
	transform-style: preserve-3d;
	will-change: transform;
}
#avatar.rotate {
	transform: rotateY(180deg);
}
.avatar-segment {
	/* The color is set via bg-primary-dark, but you can override here if needed */
	pointer-events: none;
	z-index: 2;
	transition: background 0.2s;
}

.avatar-segment {
	pointer-events: none;
	z-index: 2;
	transition: background 0.2s;
	position: absolute;
}
.avatar-segment::after {
	content: '';
	display: block;
	position: absolute;
	background: black;
	inset: 0;
	bottom: 100%;
	top: -5px;
	border-radius: 2px;
	transform: rotateX(90deg);
	transform-origin: bottom;
} 
</style>
<script>
	// Avatar rotation
	const avatar = document.getElementById('avatar');
	avatar?.addEventListener('click', () => {
		avatar.classList.toggle('rotate');
	});

	window.addEventListener('DOMContentLoaded', () => {
		// # Make fun of guests.
		// Button position shift on mouse down
		const targetA = document.getElementById('target-a');
		const targetB = document.getElementById('target-b');		
		
		if (!targetA || !targetB) {
			console.error('Target buttons not found');
			return;
		}
		
		const areas = ['a', 'b', 'c']
		const getButtonsGridEmptyArea = () => {
			const targetAArea = targetA?.className.match(/grid-area:([abc])/)?.[1];
			const targetBArea = targetB?.className.match(/grid-area:([abc])/)?.[1];
			return areas.find(area => area !== targetAArea && area !== targetBArea);
		};

		targetA.addEventListener('keydown', (e) => {
			if (e.key === 'Enter') {
				alert('You are a genius!');
			}
		});
		
		targetB.addEventListener('keydown', (e) => {
			if (e.key === 'Enter') {
				alert('You are b genius!');
			}
		});
		

		targetA.addEventListener('mousedown', (e) => {
			const emptyArea = getButtonsGridEmptyArea();
			targetA.className = targetA.className.replace(/grid-area:([abc])/, `grid-area:${emptyArea}`);
		});

		targetB.addEventListener('mousedown', (e) => {
			const emptyArea = getButtonsGridEmptyArea();
			targetB.className = targetB.className.replace(/grid-area:([abc])/, `grid-area:${emptyArea}`);
		});
	});
</script>
