---
import { Image } from 'astro:assets';
import avatarImage from "/src/assets/images/avatar.jpg"

import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';
// Fetch and sort blog posts
const allPosts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const latestPost = allPosts[0];
const recentPosts = allPosts.slice(1, 4);

// Use the description from the post's frontmatter
const excerpt = latestPost.data.excerpt || '';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<div class="flex flex-col md:flex-row gap-8 max-w-6xl mx-auto py-8">
			<main class="flex-1 min-w-0">
				<div class="flex flex-nowrap items-center text-2xl sm:text-4xl lg:text-5xl font-black mb-0">
					<!-- `container-type:inline-size` is used to correctly calculate `translateY` value for the segment lines. -->
					<!-- Use css variable for avatar size. -->
					<div class="shrink-0 inline-block relative mr-4 [container-type:inline-size] [--avatar-size:74px] sm:[--avatar-size:96px] w-[var(--avatar-size)] h-[var(--avatar-size)] ">
						<div id="avatar" class="transition-transform duration-2000 ease-in-out w-full h-full relative select-none">
							<Image class="inline-block w-[var(--avatar-size)] h-[var(--avatar-size)] rounded-full" alt="Mycolaos photoshot elaborated in Borderlands style" src={avatarImage} />
								{Array.from({ length: 16 }).map((_, i) => (
									<span
										class="avatar-segment absolute block bg-black transform-3d"
										style={{
											// 2πr/16 ≈ 18.85 for r=48px (48px is an example). + 3px to cover empty space created by the angle.
											width: 'calc(calc(calc(pi * 100%) / 16) + 3px)',
											// Segment thickness.
											height: '3px', 
											// Position at half of the container.
											left: '50%', 
											top: '50%',
											// 1. Translate to position centrally relative to the avatar.
											// 2. Rotate segment to its angle.
											// 3. After rotation, translateY away from center, 
											// the Y has now an angle created by the previous rotation.
											// Use `cqw` units for correct distance. 
											// Can't use percentages because translate % is relative to the element itself, not to the parent.
											transform: `translate(-50%, -50%) rotate(${i * 22.5}deg) translateY(-50cqw)`,
											borderRadius: '2px',
										}}
									></span>
								))}
						</div>
					</div>
					<div >
						Hello, Netwanderer!
					</div>
				</div>
				<p>
					Welcome to my little digital corner! I'm a Frontend Engineer that loves to build products and creative experiments. Sometimes, I write blog posts.
				</p>
				<p>You can read some of my blogs or have a look on one of my highlighted projects. Details are WIP, but if you want to know more about them, feel free to ping me on any of the socials you find in the footer of this website.</p>
			</main>
			
			<aside class="md:w-80 pt-16 px-4 flex-shrink-0">
				<div class="sticky top-8">
					<!-- Latest Post -->
					<div class="max-w-96 mb-6 px-3 py-6 border border-stone-300 rounded-lg bg-white/50 backdrop-blur-lg">
						<a href={`/blog/${latestPost.id}/`} class="group block">
							<h4 class="mt-0 mb-1 text-sm font-bold leading-tightgroup-hover:text-primary-dark">{latestPost.data.title}</h4>
							<p class="m-0 text-xs text-muted-dark leading-relaxed italic font-serif">{excerpt}</p>
						</a>
					</div>

					<!-- Explore -->
					<div>
						<h3 class="text-sm m-0 font-bold">Explore</h3>
						<ul class="space-y-0 list-none m-0">
							{recentPosts.map((post) => (
								<li>
									<a href={`/blog/${post.id}/`}>
										<h4 class="mt-1 mb-2 text-xs leading-tight hover:text-primary-dark">{post.data.title}</h4>
									</a>
								</li>
							))}
						</ul>
						<a href="/blog/" class="inline-block text-xs font-bold hover:text-primary-dark border-b-2 border-primary hover:border-primary-dark">
							More posts →
						</a>
					</div>
				</div>
			</aside>
		</div>
		
		<Footer />
	</body>
</html>
<style>

#avatar {
	perspective: 600px;
	transform-style: preserve-3d;
	will-change: transform;
}
#avatar.rotate {
	transform: rotateY(180deg);
}
.avatar-segment {
	/* The color is set via bg-primary-dark, but you can override here if needed */
	pointer-events: none;
	z-index: 2;
	transition: background 0.2s;
}

.avatar-segment {
	pointer-events: none;
	z-index: 2;
	transition: background 0.2s;
	position: absolute;
}
.avatar-segment::after {
	content: '';
	display: block;
	position: absolute;
	background: black;
	inset: 0;
	bottom: 100%;
	top: -5px;
	border-radius: 2px;
	transform: rotateX(90deg);
	transform-origin: bottom;
} 
</style>
<script>
	// Avatar rotation
	const avatar = document.getElementById('avatar');
	avatar?.addEventListener('click', () => {
		avatar.classList.toggle('rotate');
	});
</script>
