---
/**
 * ? This is base for Demo pages. At the moment of this commit,
 * ? the only difference is that it's not using global styles, but imports 
 * ? tailwind only.
 * ? The idea is to able to copypaste demo code without the interference of 
 * ? the main site styles.
 */

import type { ImageMetadata } from 'astro';
import BaseHeadNoStyles from './BaseHeadNoStyles.astro';

interface Props {
	title: string;
	description: string;
	image?: ImageMetadata;
}

const { title, description, image } = Astro.props;
---

<BaseHeadNoStyles title={title} description={description} image={image} />